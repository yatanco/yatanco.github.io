---
import Shell from '../../layouts/Shell.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Shell title="Writing · Yatan Blumenthal Vargas" description="Essays and unfinished thoughts.">
  <section class="intro">
    <h1>Writing</h1>
    <p class="tagline">Essays and unfinished thoughts.</p>
  </section>

  <hr />

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <a class="post-title" href={`/writing/${post.slug}`}>{post.data.title}</a>
        <p class="post-meta">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          {post.data.description && <span> — {post.data.description}</span>}
        </p>
      </li>
    ))}
  </ul>
</Shell>

<style>
  .intro h1 { font-size: 1.75rem; margin: 0 0 0.5rem; }
  .tagline { color: var(--text-dim); margin: 0; }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 2rem;
  }
  .post-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text-primary);
    text-decoration: none;
  }
  .post-title:hover { color: var(--mint); text-decoration: underline; }

  .post-meta {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: 0.4rem 0 0;
  }
</style>
