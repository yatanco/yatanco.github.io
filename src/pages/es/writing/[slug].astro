---
import { getCollection } from 'astro:content';
import EssayLayout from '../../../layouts/EssayLayout.astro';
import { estimateReadingTime } from '../../../utils/reading-time';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ id, data }) => id.startsWith('es/') && !data.draft);
  const enSlugs = new Set(
    (await getCollection('writing', ({ id }) => id.startsWith('en/')))
      .map((post) => post.slug.replace(/^en\//, ''))
  );

  return posts.map((post) => {
    const slug = post.slug.replace(/^es\//, '');
    return {
      params: { slug },
      props: {
        post,
        slug,
        altLangHref: enSlugs.has(slug) ? `/writing/${slug}` : '/',
      },
    };
  });
}

const { post, altLangHref } = Astro.props;
const { Content } = await post.render();
const readingTime = estimateReadingTime(post.body);
---
<EssayLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  tags={post.data.tags}
  lang="es"
  altLangHref={altLangHref}
  readingTime={readingTime}
>
  <Content />
</EssayLayout>
