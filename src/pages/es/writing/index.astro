---
import Shell from '../../../layouts/Shell.astro';
import { getCollection } from 'astro:content';
import { estimateReadingTime } from '../../../utils/reading-time';

const posts = (await getCollection('writing', ({ id, data }) => id.startsWith('es/') && !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<Shell title="Escritura · Yatan Blumenthal Vargas" description="Ensayos y reflexiones sin terminar." lang="es" altLangHref="/writing">
  <section class="intro">
    <h1>Escritura</h1>
    <p class="tagline">Ensayos y reflexiones sin terminar.</p>
  </section>

  <hr />

  <ul class="post-list">
    {posts.map((post) => {
      const slug = post.slug.replace(/^es\//, '');
      const minutes = estimateReadingTime(post.body);
      return (
        <li>
          <a class="post-title" href={`/es/writing/${slug}`}>{post.data.title}</a>
          <p class="post-meta">
            {post.data.date.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
            <span> · {minutes} min de lectura</span>
            {post.data.description && <span> — {post.data.description}</span>}
          </p>
        </li>
      );
    })}
  </ul>
</Shell>

<style>
  .intro h1 { font-size: 1.75rem; margin: 0 0 0.5rem; }
  .tagline { color: var(--text-dim); margin: 0; }

  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .post-list li {
    margin-bottom: 2rem;
  }
  .post-title {
    font-family: var(--serif);
    font-size: 1.3rem;
    color: var(--text-primary);
    text-decoration: none;
  }
  .post-title:hover { color: var(--mint); text-decoration: underline; }

  .post-meta {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    margin: 0.4rem 0 0;
  }
</style>
