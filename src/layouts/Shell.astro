---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Brain health, decentralized science, and thoughtful systems.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://yatan.co${Astro.url.pathname}`} />
  </head>
  <body>
    <div class="shell">
      <header class="shell-nav">
        <a class="shell-home" href="/">Yatan Blumenthal Vargas</a>
        <nav>
          <a href="/">Now</a>
          <span class="sep">/</span>
          <a href="/writing">Writing</a>
          <span class="sep">/</span>
          <a href="mailto:me@yatan.co">Email</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="shell-footer">
        <a href="https://github.com/yatanco">GitHub</a>
        <span class="sep">·</span>
        <a href="https://linkedin.com/in/yatanblumenthal">LinkedIn</a>
        <span class="sep">·</span>
        <a href="mailto:me@yatan.co">Email</a>
      </footer>
    </div>
  </body>
</html>

<style>
  .shell {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .shell-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1.25rem;
    margin-bottom: 2.5rem;
    font-family: var(--mono);
  }

  .shell-home {
    color: var(--text-primary);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .shell-home:hover { color: var(--mint); text-decoration: none; }

  nav {
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  nav a { color: var(--text-dim); }
  nav a:hover { color: var(--mint); }

  .sep {
    color: var(--rule);
    margin: 0 0.35rem;
  }

  .shell-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  .shell-footer a { color: var(--text-dim); }
  .shell-footer a:hover { color: var(--mint); }

  @media (max-width: 700px) {
    .shell { padding: 2rem 1.25rem 3rem; }
  }
</style>
