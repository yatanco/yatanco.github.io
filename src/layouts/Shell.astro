---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  lang?: 'en' | 'es';
  altLangHref?: string;
}

const {
  title,
  description = 'Operator and builder working on brain health, practical products, and human systems. Based in Cartagena, Colombia.',
  lang = 'en',
  altLangHref = lang === 'en' ? '/es' : '/',
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://yatan.co${Astro.url.pathname}`} />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-C4MCQHJQY0"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-C4MCQHJQY0');
    </script>
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('theme');
        var theme = stored || (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>
  </head>
  <body>
    <div class="shell">
      <header class="shell-nav">
        <a class="shell-home" href="/">Yatan Blumenthal Vargas</a>
        <div class="shell-controls">
          <nav>
            <a href="/">Now</a>
            <span class="sep">/</span>
            <a href="/writing">Writing</a>
          </nav>
          <div class="lang-toggle">
            {lang === 'en' ? (
              <>
                <span class="lang-current">🇺🇸</span>
                <span class="lang-sep">·</span>
                <a href={altLangHref}>🇨🇴</a>
              </>
            ) : (
              <>
                <a href={altLangHref}>🇺🇸</a>
                <span class="lang-sep">·</span>
                <span class="lang-current">🇨🇴</span>
              </>
            )}
          </div>
          <button class="theme-toggle" data-theme-toggle type="button" aria-label="Toggle color theme">☾</button>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="shell-footer">
        <a href="https://github.com/yatanco">GitHub</a>
        <span class="sep">·</span>
        <a href="https://linkedin.com/in/yatanblumenthal">LinkedIn</a>
        <span class="sep">·</span>
        <a href="https://instagram.com/yatan.co">Instagram</a>
        <span class="sep">·</span>
        <a href="https://x.com/yatanco">X</a>
      </footer>
    </div>
    <script>
      const btn = document.querySelector('[data-theme-toggle]');
      const label = (theme) => (theme === 'light' ? '☀' : '☾');
      const describe = (theme) => (theme === 'light' ? 'Switch to dark theme' : 'Switch to light theme');

      function sync() {
        const theme = document.documentElement.getAttribute('data-theme') || 'dark';
        btn.textContent = label(theme);
        btn.setAttribute('aria-label', describe(theme));
      }
      sync();

      btn?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = current === 'light' ? 'dark' : 'light';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        sync();
      });
    </script>
  </body>
</html>

<style>
  .shell {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }

  .shell-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 1.25rem;
    margin-bottom: 2.5rem;
    font-family: var(--mono);
  }

  .shell-home {
    color: var(--text-primary);
    font-weight: 700;
    font-size: 0.95rem;
  }
  .shell-home:hover { color: var(--mint); text-decoration: none; }

  .shell-controls {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.9rem;
  }

  nav {
    font-size: 0.9rem;
    color: var(--text-dim);
  }
  nav a { color: var(--text-dim); }
  nav a:hover { color: var(--mint); }

  .sep {
    color: var(--rule);
    margin: 0 0.35rem;
  }

  .lang-toggle {
    font-size: 0.75rem;
    letter-spacing: 0.03em;
    color: var(--text-dim);
  }
  .lang-toggle a { color: var(--text-dim); }
  .lang-toggle a:hover { color: var(--mint); }
  .lang-current { opacity: 0.55; }
  .lang-sep {
    color: var(--rule);
    margin: 0 0.3rem;
  }

  .theme-toggle {
    background: none;
    border: none;
    padding: 0;
    line-height: 1;
    font-size: 1rem;
    color: var(--text-dim);
    cursor: pointer;
  }
  .theme-toggle:hover { color: var(--mint); }

  .shell-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--text-dim);
  }
  .shell-footer a { color: var(--text-dim); }
  .shell-footer a:hover { color: var(--mint); }

  @media (max-width: 700px) {
    .shell { padding: 2rem 1.25rem 3rem; }
  }
</style>
