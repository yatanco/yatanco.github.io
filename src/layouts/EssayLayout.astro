---
import Shell from './Shell.astro';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
}

const { title, date, description, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<Shell title={`${title} · Yatan Blumenthal Vargas`} description={description}>
  <article class="essay">
    <header class="essay-header">
      <p class="essay-meta">
        {formattedDate}
        {tags.length > 0 && (
          <>
            <span class="sep">·</span>
            {tags.join(', ')}
          </>
        )}
      </p>
      <h1>{title}</h1>
    </header>
    <div class="essay-body">
      <slot />
    </div>
    <footer class="essay-footer">
      <a href="/writing">&larr; Back to writing</a>
    </footer>
  </article>
</Shell>

<style>
  .essay {
    max-width: var(--read-max-width);
    margin: 0 auto;
  }

  .essay-header {
    margin-bottom: 3rem;
  }

  .essay-meta {
    font-family: var(--mono);
    font-size: 0.8rem;
    letter-spacing: 0.02em;
    color: var(--read-text-dim);
    text-transform: uppercase;
    margin: 0 0 0.75rem;
  }
  .essay-meta .sep { margin: 0 0.5rem; color: var(--rule); }

  .essay-header h1 {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(2rem, 4vw, 2.75rem);
    line-height: 1.15;
    color: var(--read-text);
    margin: 0;
  }

  .essay-body {
    font-family: var(--serif);
    font-size: 1.15rem;
    line-height: var(--read-line-height);
    color: var(--read-text);
  }

  .essay-body :global(p) {
    margin: 0 0 1.5rem;
  }

  .essay-body :global(h2) {
    font-family: var(--serif);
    font-weight: 600;
    font-size: 1.5rem;
    margin: 2.5rem 0 1rem;
    color: var(--read-text);
  }

  .essay-body :global(a) {
    color: var(--read-text);
    text-decoration: underline;
    text-decoration-color: var(--read-accent);
    text-underline-offset: 3px;
  }

  .essay-body :global(blockquote) {
    border-left: 2px solid var(--read-accent);
    margin: 2rem 0;
    padding-left: 1.25rem;
    color: var(--read-text-dim);
    font-style: italic;
  }

  .essay-footer {
    margin-top: 4rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule);
    font-family: var(--mono);
    font-size: 0.85rem;
  }
</style>
